# === Feature Toggles (set to true to enable external services) ===
KUZU_ENABLED=false
REDIS_ENABLED=false
MEILI_ENABLED=false
ETL_ENABLED=false

# === Kuzu (Embedded Graph DB) ===
KUZU_DB_PATH=./data/kuzu

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Meilisearch ===
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=infranexus-dev-key

# === ServiceNow ===
SNOW_INSTANCE=https://your-instance.service-now.com
SNOW_USERNAME=
SNOW_PASSWORD=

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === CORS ===
CORS_ORIGINS=["http://localhost:3000"]

# === Rate Limiting ===
RATE_LIMIT_PER_MIN=100

# === Cache TTLs (seconds) ===
CACHE_NEIGHBORHOOD_TTL=300
CACHE_CI_TTL=600
CACHE_SEARCH_TTL=60

# === ETL ===
ETL_SYNC_INTERVAL_MIN=30

# === Graph Defaults ===
MAX_NODES_DEFAULT=500
MAX_NODES_LIMIT=2000
DEGREE_THRESHOLD_DEFAULT=50
